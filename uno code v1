//*******************************libraries********************************
#include <SPI.h>
#include <MFRC522.h>
#include <ESP8266WiFi.h>
#include <ESP8266HTTPClient.h>
#include <WiFiClient.h>

//************************************************************************
// আপনার ফিক্সড হার্ডওয়্যার অনুযায়ী পিন কনফিগারেশন
#define RST_PIN 0  // D3
#define SS_PIN  2  // D4
#define BUZZER  4  // D2
//************************************************************************

MFRC522 mfrc522(SS_PIN, RST_PIN); 

const char *ssid = "Virus";
const char *password = "01511689464";
const char *device_token = "366322a0053aa159";

String URL = "http://qarfid.punorpath.com/getdata.php";
String OldCardID = "";
unsigned long previousMillis = 0;

void setup() {
  delay(1000);
  Serial.begin(115200);
  SPI.begin();      
  mfrc522.PCD_Init(); 
  
  // বাজার পিন সেটআপ
  pinMode(BUZZER, OUTPUT);
  digitalWrite(BUZZER, LOW); 

  connectToWiFi();
}

void loop() {
  if(WiFi.status() != WL_CONNECTED){
    connectToWiFi();    
  }
  
  // ১৫ সেকেন্ড পর পর কার্ড মেমোরি ক্লিয়ার করা
  if (millis() - previousMillis >= 15000) {
    previousMillis = millis();
    OldCardID = "";
  }
  
  delay(50);
  
  if ( ! mfrc522.PICC_IsNewCardPresent()) {
    return;
  }
  
  if ( ! mfrc522.PICC_ReadCardSerial()) {
    return;
  }
  
  String CardID = "";
  for (byte i = 0; i < mfrc522.uid.size; i++) {
    CardID += mfrc522.uid.uidByte[i];
  }
  
  if( CardID == OldCardID ){
    return;
  }
  else{
    OldCardID = CardID;
    SendCardID(CardID); // ডাটা পাঠানো শুরু
  }
  delay(1000);
}

void SendCardID( String Card_uid ){
  Serial.println("Sending the Card ID...");
  
  if(WiFi.status() == WL_CONNECTED){
    WiFiClient client;
    HTTPClient http;
    
    String getData = "?card_uid=" + String(Card_uid) + "&device_token=" + String(device_token); 
    String Link = URL + getData;
    
    if (http.begin(client, Link)) { 
      int httpCode = http.GET(); 
      String payload = http.getString(); 

      Serial.print("HTTP Code: ");
      Serial.println(httpCode);

      // যদি সার্ভারে সফলভাবে ডাটা পৌঁছায় (HTTP Code 200)
      if (httpCode == 200) {
        Serial.println("Data Sent Successfully!");
        
        // সফলভাবে ডাটা পাঠালে বাজার সিগন্যাল (২বার বিপ)
        digitalWrite(BUZZER, HIGH);
        delay(150);
        digitalWrite(BUZZER, LOW);
        delay(100);
        digitalWrite(BUZZER, HIGH);
        delay(150);
        digitalWrite(BUZZER, LOW);

        if (payload.substring(0, 5) == "login") {
           Serial.println("Status: Login");
        }
        else if (payload.substring(0, 6) == "logout") {
           Serial.println("Status: Logout");
        }
      } 
      else {
        // যদি সার্ভারে পাঠাতে ব্যর্থ হয় (একটি লম্বা বিপ)
        Serial.println("Failed to send data");
        digitalWrite(BUZZER, HIGH);
        delay(600);
        digitalWrite(BUZZER, LOW);
      }
      http.end(); 
    }
  } else {
    Serial.println("WiFi Disconnected");
  }
}

void connectToWiFi(){
    WiFi.mode(WIFI_OFF);        
    delay(1000);
    WiFi.mode(WIFI_STA);
    Serial.print("Connecting to ");
    Serial.println(ssid);
    WiFi.begin(ssid, password);
    
    while (WiFi.status() != WL_CONNECTED) {
      delay(500);
      Serial.print(".");
    }
    
    Serial.println("\nConnected Successfully!");
    // ওয়াইফাই কানেক্ট হলে একটি ছোট বিপ
    digitalWrite(BUZZER, HIGH);
    delay(200);
    digitalWrite(BUZZER, LOW);
}
